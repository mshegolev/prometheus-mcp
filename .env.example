# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Prometheus server URL (no trailing slash)
PROMETHEUS_URL=https://prometheus.example.com

# Optional: Bearer token for authentication (takes precedence over Basic auth)
# PROMETHEUS_TOKEN=your-token-here

# Optional: HTTP Basic auth credentials (used only when PROMETHEUS_TOKEN is not set)
# PROMETHEUS_USERNAME=admin
# PROMETHEUS_PASSWORD=secret

# Optional: Set to 'false' to skip TLS certificate verification (e.g. for self-signed certs)
# PROMETHEUS_SSL_VERIFY=true

# Optional: HTTP request timeout in seconds (default: 30)
# PROMETHEUS_TIMEOUT=30

# Optional: Maximum HTTP response body size in bytes (default: 10485760 = 10MB)
# Protects against runaway queries returning huge responses
# PROMETHEUS_MAX_RESPONSE_BYTES=10485760

# Optional: Cache TTL for metric name lists in seconds (default: 300)
# Set to 0 to disable caching
# PROMETHEUS_CACHE_TTL=300

# ── Federation (multi-instance) config ────────────────────────────────────────
# Optional: Path to a JSON config file that defines named Prometheus/Alertmanager
# instances for federation mode.  When set, env vars above are ignored and all
# instances are read from the config file instead.  See README for the schema.
# PROMETHEUS_MCP_CONFIG=prometheus-mcp.json

# ── Alertmanager (single-instance mode) ──────────────────────────────────────
# Optional: Alertmanager URL (required for alertmanager_* tools)
# ALERTMANAGER_URL=https://alertmanager.example.com

# Optional: Alertmanager auth (same priority as Prometheus: token > basic > none)
# ALERTMANAGER_TOKEN=your-token-here
# ALERTMANAGER_USERNAME=admin
# ALERTMANAGER_PASSWORD=secret
# ALERTMANAGER_SSL_VERIFY=true
